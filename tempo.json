{
    "proposal": {
        "title": "Add Specs: TEMPO",
        "description": "Adding new specification support for relaying Tempo data on Lava. Tempo is a Stripe/Paradigm payments-focused, Reth-based EVM Layer-1 with Simplex BFT consensus and sub-second (~0.5s) deterministic instant finality (no reorgs); the spec imports ETH1 and adds Tempo-specific JSON-RPC methods (eth_sendRawTransactionSync, eth_getStorageValues, eth_getBlockAccessList, eth_simulateV1, eth_fillTransaction, tempo_forkSchedule) plus a txpool add-on. Tempo has no native gas token (fees are paid in stablecoins/TIP-20 tokens, so eth_getBalance returns a placeholder constant). The inherited ERC-4337 bundler add-on is disabled because Tempo nodes do not serve bundler RPC (no in-protocol bundler/paymaster/EntryPoint). The separate authenticated hosted REST 'Tempo API' (api.tempo.xyz) is out of scope for this JSON-RPC spec.",
        "specs": [
            {
                "index": "TEMPO",
                "name": "Tempo Mainnet",
                "enabled": true,
                "reliability_threshold": 268435455,
                "data_reliability_enabled": true,
                "block_distance_for_finalized_data": 1,
                "blocks_in_finalization_proof": 1,
                "average_block_time": 500,
                "allowed_block_lag_for_qos_sync": 20,
                "imports": [
                    "ETH1"
                ],
                "shares": 1,
                "min_stake_provider": {
                    "denom": "ulava",
                    "amount": "5000000000"
                },
